# .env.example — AgentBuff Co-Founder (server config). Copy to .env.local and fill in.
# NEVER commit real secrets. End-user BYOK keys are NOT here — users provide them at runtime,
# stored envelope-encrypted (PRD §13.1). Everything below is OPTIONAL; the app runs with none of it.
# Full guide: docs/INFRA-SETUP.md.

# --- App ---
NODE_ENV=development
# Dev server runs on port 1717 (pnpm dev).

# --- Auth (Auth.js / Google) — PRD §9.1 ---
AUTH_SECRET=                 # openssl rand -base64 32  (required in production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- BYOK envelope encryption master key — PRD §13.1 ---
BYOK_MASTER_KEY_BASE64=      # 32 random bytes, base64 (required in production)

# --- Database (PostgreSQL / Prisma) — unset => in-memory runtime ---
DATABASE_URL=                # postgresql://user:pass@host:5432/agentbuff_cofounder?schema=public

# --- Async jobs (Redis) — unset => in-memory job queue. PRD 10.3 ---
REDIS_URL=                   # redis://localhost:6379

# --- Object storage — default is durable local disk (.data/storage). Set these for S3. PRD 10.2 ---
STORAGE_DIR=                 # override local disk dir (default ./.data/storage)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=ap-southeast-2
STORAGE_S3_ENDPOINT=         # optional: MinIO / Cloudflare R2 endpoint
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_URL_TTL=3600      # presigned URL lifetime (seconds)

# --- Deep Research (Gemini Interactions API revision) — PRD 12.8, verify before prod (12.13) ---
GEMINI_API_REVISION=2026-05-20
