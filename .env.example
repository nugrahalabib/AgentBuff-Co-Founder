# .env.example — AgentBuff Co-Founder (server config)
# Copy to .env and fill in. NEVER commit .env. NO real secrets here.
#
# NOTE: End-user BYOK credentials (Gemini / OpenAI API keys, Codex tokens) are NOT stored here.
# They are provided by each user at runtime and stored ENCRYPTED (envelope/KMS). See PRD §13.1.

# --- App ---
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# --- Database / cache / queue (PRD §10) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/agentbuff
REDIS_URL=redis://localhost:6379

# --- Object storage (S3-compatible; region asia-southeast2 / Jakarta) ---
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# --- KMS / Vault for envelope encryption of BYOK credentials (PRD §13.1) ---
KMS_PROVIDER=            # e.g. gcp-kms | aws-kms | vault
KMS_KEY_REF=             # master key resource id (NOT a raw key)

# --- Google OAuth (Google-only login, PRD §9.1) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Partner SSO / Webhook Federation (OIDC, PRD §9.1.3.1) — optional ---
PARTNER_FEDERATION_JWKS_URL=

# --- Optional: limited server-side demo key for "Coba sebelum komit" (PRD R1/Q2) ---
# Keep tiny quota; rate-limit hard. Optional, off by default.
DEMO_PROVIDER=           # gemini | openai
DEMO_API_KEY=

# --- Observability (no PII / no API keys in logs, PRD §13.1, §15.7) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
